

# === APACHE REWRITE GÜVENLİK KURALLARI ===
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Localhost'ta domain yönlendirmesi yapma
    RewriteCond %{HTTP_HOST} ^localhost$ [NC,OR]
    RewriteCond %{HTTP_HOST} ^127\.0\.0\.1$ [NC]
    RewriteRule ^ - [L]

    # HTTPS'e yönlendir (cPanel/Cloudflare proxy uyumlu - sonsuz döngüyü önler)
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
    RewriteRule ^ https://www.emresigorta.net%{REQUEST_URI} [R=301,L]

    # Tüm gelen istekleri www.emresigorta.net adresine yönlendir
    RewriteCond %{HTTP_HOST} !^www\.emresigorta\.net$ [NC]
    RewriteRule ^(.*)$ https://www.emresigorta.net/$1 [R=301,L]

    # logs dizinine erişimi tamamen engelle
    RewriteRule ^logs/ - [F,L]

    # includes dizinine doğrudan erişimi engelle
    RewriteRule ^includes/ - [F,L]

    # poyrazlogin/includes dizinine doğrudan erişimi engelle
    RewriteRule ^poyrazlogin/includes/ - [F,L]

    # API dizinine dışarıdan erişimi engelle (sadece kendi sitemizden AJAX)
    RewriteCond %{HTTP_REFERER} !^https?://(localhost|www\.emresigorta\.net) [NC]
    RewriteRule ^api/ - [F,L]

    # uploads/ruhsat dizinine dışarıdan erişimi engelle
    RewriteRule ^uploads/ruhsat/ - [F,L]

    # uploads ve assets altında PHP dosyası çalıştırmayı engelle (dosya yükleme saldırılarına karşı)
    RewriteRule ^assets/.*\.php$ - [F,L]
    RewriteRule ^uploads/.*\.php$ - [F,L]

    # Hassas dosya uzantılarına erişimi engelle (env, log, sql, bak, config, ini, dist, old, tmp, swp)
    RewriteRule \.(env|log|sql|bak|config|ini|dist|old|tmp|swp)$ - [F,L]

    # Zararlı query string ve script injection denemelerini engelle
    RewriteCond %{QUERY_STRING} (<script|%3Cscript) [NC,OR]
    RewriteCond %{QUERY_STRING} (javascript:) [NC,OR]
    RewriteCond %{QUERY_STRING} (vbscript:) [NC,OR]
    RewriteCond %{QUERY_STRING} (<iframe|%3Ciframe) [NC,OR]
    RewriteCond %{QUERY_STRING} (union.*select) [NC,OR]
    RewriteCond %{QUERY_STRING} (insert.*into) [NC,OR]
    RewriteCond %{QUERY_STRING} (drop.*table) [NC,OR]
    RewriteCond %{QUERY_STRING} (\.\./) [NC,OR]
    RewriteCond %{QUERY_STRING} (%00) [NC,OR]
    RewriteCond %{QUERY_STRING} (eval\() [NC,OR]
    RewriteCond %{QUERY_STRING} (base64_encode) [NC,OR]
    RewriteCond %{QUERY_STRING} (GLOBALS|_REQUEST|_GET|_POST|_FILES|_COOKIE|_SERVER|_ENV) [NC]
    RewriteRule .* - [F,L]

    # HTTP_HOST manipülasyonunu engelle (sadece kendi domainlerinden erişim)
    RewriteCond %{HTTP_HOST} !^(localhost|emresigorta\.net|www\.emresigorta\.net)$ [NC]
    RewriteRule .* - [F,L]

    # Var olmayan dosya veya dizinler için özel 404.php göster (sadece sayfa isteklerinde)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} \.(php|html|htm)$ [NC]
    RewriteRule ^(.*)$ /404.php [L]
</IfModule>

# === GENEL DİZİN VE DOSYA KORUMALARI ===
# Dizin listelemeyi kapat, CGI çalıştırmayı engelle, symbolic link desteği
Options -Indexes -ExecCGI +FollowSymLinks

# .htaccess dosyalarına erişimi engelle
<Files ".htaccess">
    Require all denied
</Files>

# includes, logs, poyrazlogin/includes altındaki hassas dosya tiplerine erişimi engelle
<FilesMatch "\.(php|log|sql|bak|config|ini|sh|env)$">
    <If "%{REQUEST_URI} =~ m#^/(includes|logs|poyrazlogin/includes)/#">
        Require all denied
    </If>
</FilesMatch>

# === HATA YÖNLENDİRMELERİ ===
# Tüm 404 ve 403 hatalarında özel 404.php göster
ErrorDocument 404 /404.php
ErrorDocument 403 /404.php
# Güvenlik Başlıkları
<IfModule mod_headers.c>
    # XSS Koruması
    Header always set X-XSS-Protection "1; mode=block"
    
    # Clickjacking Koruması
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # MIME Sniffing Koruması
    Header always set X-Content-Type-Options "nosniff"
    
    # Referrer Politikası
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # İzin Politikası
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    
    # Sunucu bilgisini gizle
    Header unset X-Powered-By
    Header unset Server
    
    # Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'self';"
</IfModule>

# PHP güvenlik ayarları
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag expose_php Off
    php_value upload_max_filesize 10M
    php_value post_max_size 16M
    php_value max_execution_time 60
    php_value max_input_time 60
    php_flag allow_url_fopen Off
    php_flag allow_url_include Off
</IfModule>

# Dosya türü erişim kısıtlamaları
<FilesMatch "\.(sql|log|bak|old|tmp|swp|dist|env|config|ini)$">
    Require all denied
</FilesMatch>

# Belirli dosya türlerine izin ver
<FilesMatch "\.(php|html|htm|css|js|jpg|jpeg|png|gif|svg|ico|woff|woff2|ttf|eot|webp|avif)$">
    Require all granted
</FilesMatch>

# Hata sayfaları
ErrorDocument 403 /index.php
ErrorDocument 404 /index.php
ErrorDocument 500 /index.php

# ETag'i kaldır (bilgi sızıntısını önle)
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None

# === PERFORMANS: GZIP SIKIŞTIRMA ===
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf application/font-woff application/font-woff2
</IfModule>

# WebP MIME tipi (eski Apache sürümleri için gerekebilir)
<IfModule mod_mime.c>
    AddType image/webp .webp
</IfModule>

# === PERFORMANS: STATIK DOSYA CACHE (Browser Cache) ===
<IfModule mod_expires.c>
    ExpiresActive On
    # Resimler - 1 yıl
    ExpiresByType image/jpeg          "access plus 1 year"
    ExpiresByType image/png           "access plus 1 year"
    ExpiresByType image/gif           "access plus 1 year"
    ExpiresByType image/webp          "access plus 1 year"
    ExpiresByType image/avif          "access plus 1 year"
    ExpiresByType image/svg+xml       "access plus 1 year"
    ExpiresByType image/x-icon        "access plus 1 year"
    # Yazı tipleri - 1 yıl
    ExpiresByType font/woff           "access plus 1 year"
    ExpiresByType font/woff2          "access plus 1 year"
    ExpiresByType application/font-woff  "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    # CSS & JS - 1 hafta
    ExpiresByType text/css            "access plus 1 week"
    ExpiresByType text/javascript     "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    # HTML/PHP - no-cache
    ExpiresByType text/html           "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # Resimler ve fontlar için immutable cache
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|svg|ico|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # CSS ve JS için 1 hafta cache
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=604800, stale-while-revalidate=86400"
    </FilesMatch>
</IfModule>
